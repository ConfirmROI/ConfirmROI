# Flask
FLASK_CONFIG=development
SECRET_KEY=dev-secret-key-change-in-production

# JWT
JWT_SECRET_KEY=jwt-dev-secret-change-in-production
JWT_ACCESS_TOKEN_EXPIRES=3600
JWT_REFRESH_TOKEN_EXPIRES=2592000

# Database
DATABASE_URL=sqlite:///confirmroi.db
# For PostgreSQL:
# DATABASE_URL=postgresql://confirmroi:confirmroi@localhost:5432/confirmroi
DB_PASSWORD=confirmroi

# Frontend
VITE_API_URL=http://localhost:5000/api
# VITE_IS_PAID=true  # Set to "true" for the paid SaaS version (shows plan selection on register)

# Demo seeding (used by docker-compose.demo-*.yml overrides)
# DEMO_TIER=free        # "free" or "paid" — controls which users/teams/projects are seeded
# DEFAULT_USER_TIER=free # tier assigned to newly registered users in the demo environment
